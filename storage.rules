rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // All media is stored under private paths scoped by stateId + childId.
    // Firebase Storage rules cannot do Firestore lookups, so stateId
    // enforcement is handled at the service layer (storage.ts).
    // Here we require auth and enforce the path structure.
    //
    // Path: states/{stateId}/children/{childId}/{fileName}

    match /states/{stateId}/children/{childId}/{fileName} {
      // Public read: gallery and public profile pages are unauthenticated.
      // Paths are non-guessable (childId is a Firestore-generated ID,
      // fileName is timestamp-prefixed), so opening reads here is safe.
      // Write and delete remain auth-gated.
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 500 * 1024 * 1024   // 500 MB max
                   && (
                     request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('video/.*')
                   );
      allow delete: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
