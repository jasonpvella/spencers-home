rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userStateId() {
      return userDoc().stateId;
    }

    function userRole() {
      return userDoc().role;
    }

    function isPlatformAdmin() {
      return isAuth() && userRole() == 'platform_admin';
    }

    function isStateAdmin() {
      return isAuth() && userRole() in ['state_admin', 'platform_admin'];
    }

    function isCaseworkerOrAbove() {
      return isAuth() && userRole() in [
        'caseworker', 'supervisor', 'agency_admin', 'state_admin', 'platform_admin'
      ];
    }

    function belongsToState(stateId) {
      return isAuth() && userStateId() == stateId;
    }

    // ── Users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId
        || isPlatformAdmin()
        || (isStateAdmin() && resource.data.stateId == userStateId())
      );

      // Self-registration: user can create their own doc immediately after
      // Firebase Auth account creation. Role is locked to caseworker
      // at create time — no self-escalation to admin roles.
      allow create: if isAuth()
        && request.auth.uid == userId
        && request.resource.data.role == 'caseworker'
        && request.resource.data.stateId is string;

      // Platform admin: full update authority.
      // State admin: can activate/deactivate and change roles for users in
      //   their own state, but cannot set or preserve platform_admin role.
      // Self: user can update their own lastLoginAt only.
      allow update: if isPlatformAdmin()
        || (isStateAdmin()
            && belongsToState(resource.data.stateId)
            && request.resource.data.role != 'platform_admin')
        || (isAuth()
            && request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt']));

      allow delete: if false;

    }

    // ── State-scoped data ────────────────────────────────────────────────────

    match /states/{stateId} {

      // State document — stores state config (branding, consent model, PII rules).
      // State admin can read/write their own state. Platform admin has full access.
      allow read: if isStateAdmin() && (belongsToState(stateId) || isPlatformAdmin());
      allow write: if isStateAdmin() && (belongsToState(stateId) || isPlatformAdmin());

      // Children
      // Public: anyone can read profiles with status == 'published'
      // Auth: caseworker+ from matching state can read all, write with stateId validation
      match /children/{childId} {
        allow read: if
          resource.data.status == 'published'
          || (isCaseworkerOrAbove() && belongsToState(stateId));

        allow create: if
          isCaseworkerOrAbove()
          && belongsToState(stateId)
          && request.resource.data.stateId == stateId;

        allow update: if
          // Caseworker+ from matching state can update profile fields.
          // Only supervisor+ can transition status to 'published'.
          (isCaseworkerOrAbove()
            && belongsToState(stateId)
            && request.resource.data.stateId == stateId
            && (request.resource.data.status != 'published'
                || resource.data.status == 'published'
                || userRole() in ['supervisor', 'agency_admin', 'state_admin', 'platform_admin']))
          // Anyone may increment viewCount by exactly 1 (fire-and-forget view tracking)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
              && request.resource.data.viewCount == resource.data.viewCount + 1)
          // Public inquiry submission may increment inquiryCount by exactly 1
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['inquiryCount'])
              && request.resource.data.inquiryCount == resource.data.inquiryCount + 1);

        // No hard deletes — use status: 'archived'
        allow delete: if false;

        // Inquiries — public users can create (no auth required for gallery CTA)
        // Caseworkers from the same state can read. No updates or deletes.
        match /inquiries/{inquiryId} {
          allow create: if true;
          allow read: if isCaseworkerOrAbove() && belongsToState(stateId);
          allow update, delete: if false;
        }
      }

      // Notifications — written by public inquiry flow (no auth required to create)
      // Only the target user can read or mark as read.
      // Update is restricted to the read field only — no other fields may change.
      match /notifications/{notifId} {
        allow create: if true;
        allow read: if isAuth() && request.auth.uid == resource.data.userId;
        allow update: if isAuth()
          && request.auth.uid == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if false;
      }

      // Consents
      // Only caseworker+ from matching state can read/write.
      // Updates are restricted to status and expiresAt — core consent fields
      // (signedBy, signedAt, formData, auditTrail) are immutable after creation.
      match /consents/{consentId} {
        allow read: if isCaseworkerOrAbove() && belongsToState(stateId);

        allow create: if
          isCaseworkerOrAbove()
          && belongsToState(stateId)
          && request.resource.data.stateId == stateId;

        allow update: if
          isCaseworkerOrAbove()
          && belongsToState(stateId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'expiresAt']);

        allow delete: if false;
      }
    }

    // ── Sponsors ─────────────────────────────────────────────────────────────
    // Public read: shown on the landing page before auth.
    // Only platform_admin can write or delete.

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    // ── SSO providers ────────────────────────────────────────────────────────
    // Public read: login page fetches this before auth to detect SSO availability.
    // Only state admin (or platform admin) can write. Stores: enabled, providerType,
    // providerId, displayName — no secrets.

    match /ssoProviders/{stateId} {
      allow read: if true;
      allow write: if isStateAdmin() && (belongsToState(stateId) || isPlatformAdmin());
    }

    // ── Audit log ────────────────────────────────────────────────────────────
    // Append-only: authenticated users can create. Only platform_admin can read.
    // No updates or deletes — ever.

    match /audit/{logId} {
      allow read: if isPlatformAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
